#!/bin/sh
set -e

echo "-----------------------------------------------------------------"
echo "---------------------* Testing *---------------------------------"
echo "-----------------------------------------------------------------"

 deno fmt --check

echo "---------------------* Format checked *---------------------------------"

deno lint

echo "------------------* All lint passed ! *--------------------------"

deno test -A --reporter=dot

echo "------------------* All test passed ! *--------------------------"

deno test --coverage -A --reporter=dot

echo "------------------* All lines covered ! *--------------------------"

deno run -A jsr:@ashishkujoy/deno-coverage-checker

echo "------------------* coverage checker completed ! *--------------------------"

echo "-----------------------------------------------------------------"
echo "-------------------* Before Commit *-----------------------------"
echo "-----------------------------------------------------------------"